{
  "name": "@storywright/notifier-github",
  "version": "1.0.0",
  "description": "GitHub PR comment notifier for Storywright",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/macloud-developer/storywright.git",
    "directory": "packages/@storywright/notifier-github"
  },
  "files": [
    "dist"
  ],
