{
  "name": "@storywright/cli",
  "version": "1.6.2",
  "description": "Zero-config visual regression testing powered by Storybook + Playwright",
  "keywords": [
    "playwright",
    "screenshot",
    "storybook",
    "testing",
    "visual-regression-testing",
    "vrt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/macloud-developer/storywright.git",
    "directory": "packages/@storywright/cli"
  },
  "bin": {
    "storywright": "./bin/storywright.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./playwright/reporter": {
      "import": "./dist/playwright/reporter.js",
      "types": "./dist/playwright/reporter.d.ts"
    },
    "./playwright/stabilize": {
      "import": "./dist/playwright/stabilize.js",
      "types": "./dist/playwright/stabilize.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@storywright/report": "workspace:*",
    "citty": "^0.1.6",
    "consola": "^3.4.2",
    "picomatch": "^4.0.4",
    "simple-git": "^3.36.0",
    "sirv": "^3.0.2",
    "unconfig": "^0.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.17",
    "@types/picomatch": "^3.0.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
