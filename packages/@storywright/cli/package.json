{
  "name": "@storywright/cli",
  "version": "1.4.1",
  "description": "Zero-config visual regression testing powered by Storybook + Playwright",
  "keywords": [
    "playwright",
    "screenshot",
    "storybook",
    "testing",
    "visual-regression-testing",
    "vrt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/macloud-developer/storywright.git",
    "directory": "packages/@storywright/cli"
  },
  "bin": {
    "storywright": "./bin/storywright.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./playwright/reporter": {
      "import": "./dist/playwright/reporter.js",
      "types": "./dist/playwright/reporter.d.ts"
    },
    "./playwright/stabilize": {
      "import": "./dist/playwright/stabilize.js",
      "types": "./dist/playwright/stabilize.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@storywright/report": "workspace:*",
    "citty": "^0.1.6",
    "consola": "^3.2.3",
    "picomatch": "^4.0.2",
    "simple-git": "^3.32.3",
    "sirv": "^3.0.0",
    "unconfig": "^0.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "@types/picomatch": "^3.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
