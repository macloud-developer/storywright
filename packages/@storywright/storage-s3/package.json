{
  "name": "@storywright/storage-s3",
  "version": "1.2.1",
  "description": "S3 storage adapter for Storywright",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/macloud-developer/storywright.git",
    "directory": "packages/@storywright/storage-s3"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/lib-storage": "^3.750.0",
    "tar": "^7.0.0",
    "zstd-napi": "^0.0.12"
  },
  "devDependencies": {
    "@storywright/cli": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "@storywright/cli": "workspace:^"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
